generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Sex {
  MALE
  FEMALE
  OTHER
}

enum Goal {
  HYPERTROPHY
  WEIGHT_LOSS
  STRENGTH
  CONDITIONING
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ChatRole {
  USER
  ASSISTANT
}

enum SubscriptionPlan {
  FREE
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  EXPIRED
}

enum PaymentProvider {
  MOCK
  STRIPE
  MERCADO_PAGO
  APPLE_IAP
  GOOGLE_PLAY
}

model User {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  password       String
  createdAt      DateTime        @default(now())
  profile        Profile?
  subscription   Subscription?
  workoutPlans   WorkoutPlan[]
  workoutLogs    WorkoutLog[]
  bodyMetrics    BodyMetric[]
  aiChatMessages AiChatMessage[]

  @@map("users")
}

model Profile {
  userId          String           @id
  age             Int
  sex             Sex
  height          Float
  weight          Float
  goal            Goal
  experienceLevel ExperienceLevel
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model WorkoutPlan {
  id          String       @id @default(uuid())
  userId      String
  title       String
  createdAt   DateTime     @default(now())
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutDays WorkoutDay[]

  @@map("workoutPlans")
}

model WorkoutDay {
  id               String            @id @default(uuid())
  workoutPlanId    String
  dayName          String
  workoutPlan      WorkoutPlan       @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  workoutExercises WorkoutExercise[]

  @@map("workoutDays")
}

model WorkoutExercise {
  id           String     @id @default(uuid())
  workoutDayId String
  exerciseName String
  sets         Int
  reps         String
  restTime     Int
  workoutDay   WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)

  @@map("workoutExercises")
}

model WorkoutLog {
  id            String   @id @default(uuid())
  userId        String
  exerciseName  String
  weightUsed    Float
  repsPerformed Int
  completedAt   DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("workoutLogs")
}

model BodyMetric {
  id        String   @id @default(uuid())
  userId    String
  weight    Float
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bodyMetrics")
}

model AiChatMessage {
  id        String   @id @default(uuid())
  userId    String
  role      ChatRole
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("aiChatMessages")
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  billingCycleMonths   Int                @default(1)
  startedAt            DateTime           @default(now())
  expiresAt            DateTime?
  monthlyMessageLimit  Int                @default(15)
  monthlyMessagesUsed  Int                @default(0)
  usagePeriodStartedAt DateTime           @default(now())
  paymentProvider      PaymentProvider    @default(MOCK)
  providerCustomerId   String?
  providerSubscriptionId String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}
